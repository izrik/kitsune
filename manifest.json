{
  "manifest_version": 2,
  "name": "Kitsune",
  "version": "0.1",
  "description": "Manages tabs and windows",
  "homepage_url": "https://github.com/izrik/kitsune",
  "icons": {
    "48": "icons/bolt.png"
  },

  "permissions": [
    "activeTab",
    "sessions",
    "storage",
    "tabs"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_action": {
    "default_icon": "icons/bolt.png",
    "default_title": "Kitsune",
    "default_popup": "popup/popup.html"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "{01eb959e-462b-4e77-8591-dc2bde08a39c}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
