{
  "manifest_version": 3,
  "name": "Kitsune",
  "version": "0.2",
  "description": "Manages tabs and windows",
  "homepage_url": "https://github.com/izrik/kitsune",
  "icons": {
    "48": "icons/kitsune_thick.svg",
    "96": "icons/kitsune_thick.svg"
  },

  "permissions": [
    "activeTab",
    "sessions",
    "storage",
    "tabs"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_icon": "icons/kitsune_thick.svg",
    "default_title": "Kitsune",
    "default_popup": "popup/popup.html"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "{01eb959e-462b-4e77-8591-dc2bde08a39c}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
